<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:type="MailApp">
  <Id>cc3a3c6c-2796-4799-a8f7-261e1b18050d</Id>
  <Version>1.0.0</Version>
  <ProviderName>Contoso</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="MailGenerator"/>
  <Description DefaultValue="A template to get started."/>
  <IconUrl DefaultValue="https://davidlynchict.github.io/mailgenerator/assets/color.png"/>
  <HighResolutionIconUrl DefaultValue="https://davidlynchict.github.io/mailgenerator/assets/outline.png"/>
  <SupportUrl DefaultValue="https://www.contoso.com"/>
  <AppDomains>
    <AppDomain>contoso.com</AppDomain>
    <AppDomain>localhost</AppDomain>
  </AppDomains>
  
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.3">
      <Set Name="Mailbox"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <!-- Read mode -->
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://davidlynchict.github.io/mailgenerator/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>

    <!-- Compose mode -->
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://davidlynchict.github.io/mailgenerator/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>
  
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <VersionOverrides xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <!-- Read Ribbon -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup" label="Contoso Add-in">
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="showPaneLabel"/>
                  <Supertip>
                    <Title resid="showPaneLabel"/>
                    <Description resid="showPaneDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>TaskPaneRuntime</TaskpaneId>
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Compose Ribbon -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup" label="Contoso Add-in">
                <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                  <Label resid="showPaneLabel"/>
                  <Supertip>
                    <Title resid="showPaneLabel"/>
                    <Description resid="showPaneDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>TaskPaneRuntime</TaskpaneId>
                    <SourceLocation resid="taskpaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://davidlynchict.github.io/mailgenerator/assets/icon-16.png"/>
        <bt:Image id="icon32" DefaultValue="https://davidlynchict.github.io/mailgenerator/assets/icon-32.png"/>
        <bt:Image id="icon80" DefaultValue="https://davidlynchict.github.io/mailgenerator/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://davidlynchict.github.io/mailgenerator/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="showPaneLabel" DefaultValue="Show Task Pane"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="showPaneDesc" DefaultValue="Opens a pane displaying all available properties."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>